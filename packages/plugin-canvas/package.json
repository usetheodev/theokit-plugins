{
  "name": "@theokit/plugin-canvas",
  "version": "0.3.0",
  "description": "Canvas plugin for TheoKit \u2014 artifact protocol (markdown/code/svg/diff/whiteboard/slide/mermaid/html/image) + side-panel UI + agent custom tool.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "import": "./dist/ui/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "zod": "^3.24.0"
  },
  "peerDependencies": {
    "@theokit/sdk": ">=1.0.0",
    "@theokit/ui": "^0.14.2",
    "mermaid": "^11.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "theokit": ">=0.1.0-alpha.5"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "mermaid": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@theokit/ui": "^0.14.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^25.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "theokit": "link:../../../theokit/packages/theo",
    "vite": "^7.3.5",
    "vitest": "^4.1.8"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "theokit",
    "theokit-plugin",
    "canvas",
    "artifact",
    "agent-output",
    "whiteboard",
    "code-rendering",
    "mermaid",
    "slide"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/usetheodev/theokit-plugins.git",
    "directory": "packages/plugin-canvas"
  },
  "homepage": "https://github.com/usetheodev/theokit-plugins/tree/main/packages/plugin-canvas#readme",
  "bugs": {
    "url": "https://github.com/usetheodev/theokit-plugins/issues"
  },
  "license": "MIT"
}
