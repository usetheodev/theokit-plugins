{
  "name": "@theokit/plugin-realtime",
  "version": "0.1.0",
  "description": "Multiplayer realtime plugin for TheoKit — presence + room + broadcast + Yjs CRDT (opt-in). Form 4 Hybrid: RealtimeProvider interface + MemoryRealtimeProvider default + YjsRealtimeProvider + defineRealtimeProvider extension. Consumes @theokit/sdk@>=1.7.0 subscribe for WS transport. React hooks at /react sub-path. Per plan p9-plugin-realtime v1.0.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    }
  },
  "files": ["dist", "README.md", "CHANGELOG.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "theokit": ">=0.4.0-beta.0",
    "@theokit/sdk": ">=1.7.0",
    "zod": "^3.25.0 || ^4.0.0",
    "yjs": "^13",
    "y-protocols": "^1",
    "lib0": "^1",
    "react": ">=18 || >=19",
    "@types/react": ">=18 || >=19"
  },
  "peerDependenciesMeta": {
    "yjs": { "optional": true },
    "y-protocols": { "optional": true },
    "lib0": { "optional": true },
    "react": { "optional": true },
    "@types/react": { "optional": true }
  },
  "devDependencies": {
    "@testing-library/dom": "^10.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.18.0",
    "jsdom": "^25.0.0",
    "lib0": "^1.0.0-rc.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.0",
    "ws": "^8.18.0",
    "y-protocols": "^1.0.6-rc.1",
    "yjs": "^13.6.0",
    "zod": "^4.0.0"
  },
  "keywords": [
    "theokit",
    "theokit-plugin",
    "realtime",
    "websocket",
    "presence",
    "multiplayer",
    "yjs",
    "crdt",
    "awareness"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
