{
  "name": "@theokit/plugin-openapi",
  "version": "0.1.3",
  "description": "OpenAPI docs UI for TheoKit — mounts Scalar at /api/docs reading the .theo/openapi.json emitted by theokit build/dev.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "zod": "^3.24.0"
  },
  "peerDependencies": {
    "theokit": ">=0.2.1"
  },
  "devDependencies": {
    "theokit": "link:../../../theokit/packages/theo"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "theokit",
    "theokit-plugin",
    "openapi",
    "swagger",
    "scalar",
    "docs",
    "api-docs"
  ],
  "author": "@usetheo",
  "license": "MIT"
}
