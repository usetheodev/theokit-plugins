{
  "name": "@theokit/plugin-email",
  "version": "0.1.0",
  "description": "Email plugin for TheoKit — EmailProvider interface + Resend default + React Email opt-in peer + canonical magic-link template helper. Form 4 Hybrid per plan p7-plugin-email v1.0.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@react-email/components": ">=0.0.20",
    "@react-email/render": ">=1.0.0",
    "react": ">=19.0.0",
    "resend": ">=3.0.0",
    "theokit": ">=0.2.4"
  },
  "peerDependenciesMeta": {
    "@react-email/components": { "optional": true },
    "@react-email/render": { "optional": true },
    "react": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "resend": "^4.0.0",
    "theokit": "link:../../../theokit/packages/theo",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.8"
  },
  "publishConfig": { "access": "public", "provenance": true },
  "keywords": [
    "theokit",
    "theokit-plugin",
    "email",
    "resend",
    "react-email",
    "magic-link",
    "transactional"
  ],
  "author": "@theokit",
  "license": "MIT"
}
