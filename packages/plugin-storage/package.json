{
  "name": "@theokit/plugin-storage",
  "version": "0.1.0",
  "description": "S3-compatible storage plugin for TheoKit — StorageProvider interface + S3Provider config-driven (AWS/R2/MinIO/B2 via endpoint URL) + signed URL helpers (PUT/GET). Server-side only v0.1. Form 4 Hybrid per plan p8-plugin-storage v1.0.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@aws-sdk/client-s3": ">=3.500.0",
    "@aws-sdk/s3-request-presigner": ">=3.500.0",
    "theokit": ">=0.2.4"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@types/node": "^22.0.0",
    "theokit": "link:../../../theokit/packages/theo",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.8"
  },
  "publishConfig": { "access": "public", "provenance": true },
  "keywords": [
    "theokit",
    "theokit-plugin",
    "storage",
    "s3",
    "r2",
    "minio",
    "b2",
    "signed-url",
    "presigned",
    "upload"
  ],
  "author": "@theokit",
  "license": "MIT"
}
