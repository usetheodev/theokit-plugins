{
  "name": "theokit-plugins-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Official first-party plugins for the TheoKit framework",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.12.0"
  },
  "scripts": {
    "build": "pnpm -r --filter='./packages/*' run build",
    "test": "pnpm -r --filter='./packages/*' run test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'packages/**/*.{ts,tsx,mts,cts}' --max-warnings=0 --no-error-on-unmatched-pattern",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^25.6.2",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "eslint": "^9",
    "prettier": "^3.4.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8",
    "vite": "^7.3.5",
    "vitest": "^4.1.8"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/usetheodev/theokit-plugins.git"
  },
  "homepage": "https://github.com/usetheodev/theokit-plugins#readme",
  "bugs": {
    "url": "https://github.com/usetheodev/theokit-plugins/issues"
  },
  "license": "MIT",
  "pnpm": {
    "overrides": {
      "@theokit/sdk": "1.5.0"
    }
  }
}
