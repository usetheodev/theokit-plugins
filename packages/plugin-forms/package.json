{
  "name": "@theokit/plugin-forms",
  "version": "0.1.2",
  "description": "Declarative form binding for TheoKit: zod + react-hook-form + useAction. Ships <TheoForm action={actions.X}> + <TheoField name> + applyActionErrorsToForm adapter.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@hookform/resolvers": "^5.0.0",
    "@theokit/react": ">=1.1.0",
    "@theokit/ui": ">=0.13.0",
    "react": ">=19.0.0",
    "react-hook-form": "^7.50.0",
    "theokit": ">=0.2.3",
    "zod": "^3.25.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "@theokit/ui": {
      "optional": true
    }
  },
  "devDependencies": {
    "@hookform/resolvers": "^5.0.0",
    "@testing-library/react": "^16.1.0",
    "@theokit/react": "^1.1.0",
    "@theokit/ui": "^0.13.0",
    "@types/react": "^19.0.0",
    "happy-dom": "^20.9.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.50.0",
    "theokit": "link:../../../theokit/packages/theo",
    "tsup": "^8.5.0",
    "vitest": "^4.1.8",
    "zod": "^3.25.76"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "theokit",
    "theokit-plugin",
    "forms",
    "react-hook-form",
    "zod",
    "validation"
  ],
  "author": "@theokit",
  "license": "MIT"
}
